# DocuMind Docker 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# 注意：生产环境请使用强密码！

# ========================================
# 基础设施配置（必须配置）
# ========================================

# MySQL密码
MYSQL_ROOT_PASSWORD=your_mysql_password_here

# Redis密码
REDIS_PASSWORD=your_redis_password_here

# RabbitMQ配置
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_PASSWORD=your_rabbitmq_password_here

# MinIO配置
MINIO_ROOT_USER=admin
MINIO_SECRET_KEY=your_minio_secret_key_here

# ========================================
# 安全配置（必须配置）
# ========================================

# JWT密钥（至少64字符）
# 生成命令: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_here

# Gateway签名密钥（至少32字符）
# 生成命令: openssl rand -base64 32
GATEWAY_SIGNATURE_SECRET=your_gateway_secret_here

# ========================================
# AI服务配置 - DeepSeek大模型
# ========================================
# 用途：Agent对话、文档摘要、关键词提取、文本分析
# 获取地址：https://platform.deepseek.com/api_keys

# API密钥（必须配置，否则AI对话功能不可用）
OPENAI_API_KEY=your_deepseek_api_key_here

# API地址（可选，默认DeepSeek）
# 注意：不带/v1后缀，Spring AI会自动添加
OPENAI_API_BASE=https://api.deepseek.com

# 模型名称（可选，默认deepseek-chat）
# 模型名称（可选，默认deepseek-v4-flash）
# 可选值：deepseek-v4-flash, deepseek-v4-pro
# 注意：deepseek-chat将于2026/07/24弃用
OPENAI_MODEL=deepseek-v4-flash

# ========================================
# AI服务配置 - 阿里云百炼Embedding
# ========================================
# 用途：RAG知识库文档向量化、智能检索
# 获取地址：https://dashscope.console.aliyun.com/apiKey
# 如果不配置，RAG将使用模拟向量（检索效果差）
#
# 注意：Embedding API地址由阿里云SDK内置，无需配置URL
# SDK内置地址：https://dashscope.aliyuncs.com/api/v1

# Embedding API密钥（强烈建议配置）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Embedding模型（可选，默认多模态模型）
# 推荐：tongyi-embedding-vision-flash-2026-03-06（多模态，支持文本和图像，返回768维向量）
DASHSCOPE_EMBEDDING_MODEL=tongyi-embedding-vision-flash-2026-03-06

# ========================================
# 其他可选配置
# ========================================

# JWT Token过期时间（分钟）
JWT_TOKEN_EXPIRATION=30

# JWT Refresh Token过期时间（小时）
JWT_REFRESH_TOKEN_EXPIRATION=24

# ========================================
# 功能说明
# ========================================
#
# OPENAI_API_KEY 配置的API调用：
# ├── Agent对话 (/api/ai/agent/chat)
# ├── 文档摘要 (/api/ai/summarize)
# ├── 关键词提取 (/api/ai/keywords)
# └── 文本分析 (/api/ai/analyze)
#
# DASHSCOPE_API_KEY 配置的API调用：
# ├── RAG文档索引 (/api/ai/rag/index) - 向量化文档
# ├── RAG检索 (/api/ai/rag/search) - 向量检索
# └── RAG问答 (/api/ai/rag/query) - 混合检索+AI生成答案
#
# ========================================
# 安全说明
# ========================================
# 1. 所有密码应至少16字符，包含大小写字母、数字、特殊字符
# 2. JWT_SECRET 应64字符以上
# 3. 生产环境禁止使用示例值
# 4. 定期更换密码（建议每季度）
# 5. 不要将.env文件提交到Git仓库