# ========================================
# DocuMind 项目 Git 忽略规则
# ========================================

# ----- Java / Maven -----
target/
*.class
*.jar
*.war
*.ear
*.nar
*.aar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ----- IDE -----
# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
out/

# Eclipse
.project
.classpath
.settings/
.metadata/
bin/
tmp/

# VS Code
.vscode/

# NetBeans
nb-configuration.xml
nbproject/

# ----- 日志文件 -----
*.log
logs/
log/

# ----- 操作系统 -----
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ----- Docker -----
# Docker 构建缓存（本地镜像不提交）
.docker/

# ----- 配置文件（敏感信息） -----
# 本地环境配置覆盖
*.local
application-local.yml
application-local.properties

# 环境变量文件（所有目录）
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.*.local
.env
.env.local
.env.development
.env.production
.env.*.local

# ----- 临时文件 -----
*.tmp
*.temp
*.swp
*.swo
*.bak
*.cache

# ----- Node.js（前端开发） -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
dist/
build/
.cache/
.vite/

