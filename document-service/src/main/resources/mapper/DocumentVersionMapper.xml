<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaee.documentservice.mapper.DocumentVersionMapper">

    <select id="selectByDocId" resultType="com.javaee.documentservice.entity.DocumentVersion">
        SELECT * FROM doc_version WHERE doc_id = #{docId} ORDER BY version DESC
    </select>

    <select id="selectLatestVersion" resultType="com.javaee.documentservice.entity.DocumentVersion">
        SELECT * FROM doc_version
        WHERE doc_id = #{docId}
        ORDER BY version DESC
        LIMIT 1
    </select>

    <select id="selectMaxVersion" resultType="java.lang.Integer">
        SELECT COALESCE(MAX(version), 0) FROM doc_version WHERE doc_id = #{docId}
    </select>

    <select id="selectByDocIdAndVersion" resultType="com.javaee.documentservice.entity.DocumentVersion">
        SELECT * FROM doc_version
        WHERE doc_id = #{docId} AND version = #{version}
        LIMIT 1
    </select>

    <delete id="deleteByDocId">
        DELETE FROM doc_version WHERE doc_id = #{docId}
    </delete>

</mapper>
