{
  "name": "documind-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "DocuMind 企业级文档智能处理系统前端",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/",
    "type-check": "vue-tsc --noEmit",
    "clean": "rm -rf node_modules dist .vite",
    "start": "npm run dev"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "axios": "^1.16.0",
    "element-plus": "^2.14.0",
    "pinia": "^3.0.4",
    "sockjs-client": "^1.6.1",
    "stompjs": "^2.3.3",
    "vue": "^3.5.32",
    "vue-pdf-embed": "^1.2.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/sockjs-client": "^1.5.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^0.16.7",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7",
    "vitest": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vitest/coverage-v8": "^1.0.0",
    "happy-dom": "^12.0.0"
  }
}
