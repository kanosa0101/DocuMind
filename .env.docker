# ========================================
# DocuMind Docker 环境配置
# 复制此文件为 .env 并根据环境修改值
# 注意：生产环境必须使用强密码
# ========================================

# ----- MySQL配置 -----
MYSQL_ROOT_PASSWORD=DocuMindMySQL@2024#Secure
MYSQL_DATABASE=doc_ai

# ----- Redis配置 -----
REDIS_PASSWORD=DocuMindRedis@2024#Secure

# ----- RabbitMQ配置 -----
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_PASSWORD=DocuMindRabbitMQ@2024#Secure

# ----- MinIO配置 -----
MINIO_ROOT_USER=admin
MINIO_SECRET_KEY=DocuMindMinIO@2024#Secure

# ----- Grafana配置 -----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=DocuMindGrafana@2024#Secure

# ----- JWT配置 -----
# 建议: openssl rand -base64 64
JWT_SECRET=DocuMind2024SecureJWTKeyForProductionEnvironmentMinimum64CharactersRequiredPleaseGenerateYourOwnKey
JWT_TOKEN_EXPIRATION=30
JWT_REFRESH_TOKEN_EXPIRATION=24

# ----- Gateway签名密钥 -----
GATEWAY_SIGNATURE_SECRET=DocuMindGatewaySignature2024

# ----- API密钥 -----
OPENAI_API_KEY=your_openai_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ----- 数据库SSL配置 -----
MYSQL_USE_SSL=true